{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ClipVault",
  "version": "0.1.0",
  "identifier": "com.clipvault.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "ClipVault",
        "url": "index.html",
        "width": 1100,
        "height": 720,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "visible": false,
        "center": true
      },
      {
        "label": "palette",
        "title": "ClipVault Quick Paste",
        "url": "palette.html",
        "width": 720,
        "height": 520,
        "minWidth": 480,
        "minHeight": 320,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "center": true,
        "focus": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob: asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "publisher": "ClipVault",
    "category": "Productivity",
    "shortDescription": "Privacy-first local clipboard manager for Windows",
    "longDescription": "ClipVault is a native Windows clipboard manager that runs entirely on your device. Capture text, images, and files, search them instantly, and paste them back in a flash. No cloud, no telemetry, no account required.",
    "homepage": "https://clipvault.app",
    "windows": {
      "wix": {
        "language": "en-US"
      },
      "nsis": {
        "installMode": "perMachine"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "placeholder"
    }
  }
}
